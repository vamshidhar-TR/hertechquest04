# ── Claude / "the brain" (all optional) ────────────────────────────────────────
# Without any credentials the app runs fully on deterministic fallbacks:
#   - natural-language rule parsing   -> regex/keyword parser
#   - "why this matters" explanations -> templated, tax-aware text
#   - voice follow-up (/api/ask)      -> grounded template answer
#
# Pick ONE auth method:
#
# A) Via the Thomson Reuters LiteLLM gateway (no direct Anthropic key needed):
#      ANTHROPIC_BASE_URL=https://litellm.int.thomsonreuters.com
#      ANTHROPIC_AUTH_TOKEN=<your-litellm-virtual-key>   # sent as: Authorization: Bearer …
#
# B) Direct Anthropic:
#      ANTHROPIC_API_KEY=sk-ant-…
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=

# Model id. Through LiteLLM the name often carries a provider prefix, e.g.:
#   ANTHROPIC_MODEL=anthropic/claude-opus-4-7
# ANTHROPIC_MODEL applies to both calls; the per-call vars below override it if you want
# a cheaper model for NL parsing vs. explanations.
ANTHROPIC_MODEL=
ANTHROPIC_MODEL_EXPLAIN=
ANTHROPIC_MODEL_PARSE=

# Port the API listens on (frontend calls http://localhost:<PORT>/api).
PORT=3001
